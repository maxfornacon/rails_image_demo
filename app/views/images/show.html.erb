        <h2 class="text-sm title-font text-gray-500 tracking-widest"><%= @image.small_image.filename %></h2>
        <h1 class="text-gray-900 text-3xl title-font font-medium mb-1">Originalbild verkleinert Monochrom</h1>
      </div>
    </div>
  </div>
</section>
